generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VENDOR
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum RentalStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum HealthStatus {
  HEALTHY
  NEEDS_WATER
  PEST_ISSUE
  DISEASED
  HARVEST_READY
}

enum PostCategory {
  TIPS
  QUESTION
  SUCCESS_STORY
  EVENT
}

// User Model
model User {
  id              String          @id @default(uuid())
  name            String
  email           String          @unique
  password        String
  role            Role
  status          UserStatus      @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  vendorProfile   VendorProfile?
  orders          Order[]
  rentalBookings  RentalBooking[]
  communityPosts  CommunityPost[]
  communityComments CommunityComment[]
  plantTrackings  PlantTracking[]
}

// VendorProfile Model
model VendorProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  farmName           String
  farmLocation       String
  farmDescription    String?
  phoneNumber        String
  certificationStatus CertificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  
  // Relations
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  produces           Produce[]
  rentalSpaces       RentalSpace[]
  sustainabilityCerts SustainabilityCert[]
  orders             Order[]
}

// Produce Model
model Produce {
  id                 String             @id @default(uuid())
  vendorId           String
  name               String
  description        String?
  price              Float
  category           String
  certificationStatus CertificationStatus @default(PENDING)
  availableQuantity  Int
  unit               String             @default("kg")
  imageUrl           String?
  isOrganic          Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  
  // Relations
  vendor             VendorProfile      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
}

// RentalSpace Model
model RentalSpace {
  id                 String         @id @default(uuid())
  vendorId           String
  name               String
  location           String
  latitude           Float?
  longitude          Float?
  size               Float          // in square meters
  pricePerMonth      Float
  availability       Boolean        @default(true)
  description        String?
  soilType           String?
  sunlight           String?
  waterAccess        Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  // Relations
  vendor             VendorProfile  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bookings           RentalBooking[]
}

// RentalBooking Model
model RentalBooking {
  id                 String       @id @default(uuid())
  userId             String
  rentalSpaceId      String
  startDate          DateTime
  endDate            DateTime
  totalPrice         Float
  status             RentalStatus @default(PENDING)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  
  // Relations
  user               User         @relation(fields: [userId], references: [id])
  rentalSpace        RentalSpace  @relation(fields: [rentalSpaceId], references: [id])
}

// Order Model
model Order {
  id                 String       @id @default(uuid())
  userId             String
  vendorId           String
  totalAmount        Float
  status             OrderStatus  @default(PENDING)
  orderDate          DateTime     @default(now())
  shippingAddress    String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  
  // Relations
  user               User         @relation(fields: [userId], references: [id])
  vendor             VendorProfile @relation(fields: [vendorId], references: [id])
  items              OrderItem[]
}

// OrderItem Model
model OrderItem {
  id                 String    @id @default(uuid())
  orderId            String
  produceId          String
  quantity           Int
  price              Float
  createdAt          DateTime  @default(now())
  
  // Relations
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  produce            Produce   @relation(fields: [produceId], references: [id])
}

// CommunityPost Model
model CommunityPost {
  id                 String            @id @default(uuid())
  userId             String
  title              String
  postContent        String
  category           PostCategory
  likes              Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  
  // Relations
  user               User              @relation(fields: [userId], references: [id])
  comments           CommunityComment[]
}

// CommunityComment Model
model CommunityComment {
  id                 String    @id @default(uuid())
  postId             String
  userId             String
  comment            String
  createdAt          DateTime  @default(now())
  
  // Relations
  post               CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id])
}

// SustainabilityCert Model
model SustainabilityCert {
  id                 String             @id @default(uuid())
  vendorId           String
  certifyingAgency   String
  certificationNumber String            @unique
  certificationDate  DateTime
  expiryDate         DateTime
  documentUrl        String?
  status             CertificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  
  // Relations
  vendor             VendorProfile      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

// PlantTracking Model
model PlantTracking {
  id                 String            @id @default(uuid())
  userId             String
  plantName          String
  plantType          String
  plantingDate       DateTime
  expectedHarvestDate DateTime
  healthStatus       HealthStatus      @default(HEALTHY)
  notes              String?
  imageUrl           String?
  lastWatered        DateTime?
  lastFertilized     DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  
  // Relations
  user               User              @relation(fields: [userId], references: [id])
  healthUpdates      PlantHealthUpdate[]
}

// PlantHealthUpdate Model
model PlantHealthUpdate {
  id                 String       @id @default(uuid())
  plantTrackingId    String
  healthStatus       HealthStatus
  notes              String?
  imageUrl           String?
  createdAt          DateTime     @default(now())
  
  // Relations
  plantTracking      PlantTracking @relation(fields: [plantTrackingId], references: [id], onDelete: Cascade)
}